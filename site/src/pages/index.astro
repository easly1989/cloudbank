---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;
const asset = (p: string) => `${base.replace(/\/$/, "")}/${p.replace(/^\//, "")}`;
const REPO = "https://github.com/easly1989/cloudbank";
const HOMEBANK = "https://www.gethomebank.org/";

const features = [
  {
    icon: "🏦",
    title: "Every account type",
    body: "Bank, cash, checking, savings, credit card, liability, asset and investment accounts — each with its own currency, a default payment mode and the full set of HomeBank flags.",
  },
  {
    icon: "📒",
    title: "A powerful register",
    body: "Running balances, rich filtering, 12 payment types, the cleared/reconciled lifecycle, category splits, tags, bulk edit with a running selection total, and duplicate detection.",
  },
  {
    icon: "🔁",
    title: "Schedules & automation",
    body: "Scheduled transactions with automatic posting and a per-week/month/year income & expense summary, reusable templates, and assignment rules that auto-categorise as you go.",
  },
  {
    icon: "📊",
    title: "Budgets & reports",
    body: "Budgets plus Statistics, Trend, Balance, Budget and Vehicle-cost reports — interactive charts with CSV / PNG export.",
  },
  {
    icon: "📥",
    title: "Import & export",
    body: "Native HomeBank .xhb import and export, plus QIF, OFX/QFX and CSV — with a guided import assistant.",
  },
  {
    icon: "🌍",
    title: "Multi-currency",
    body: "Per-account currencies with manual or online (ECB / frankfurter.app) exchange rates and full conversion in reports.",
  },
  {
    icon: "👥",
    title: "Multi-user & private",
    body: "Admin-managed users, each with isolated wallets. Your data lives in a SQLite file on a volume you control — nothing leaves your server.",
  },
  {
    icon: "🎨",
    title: "Made yours",
    body: "A fully customisable, free-form dashboard — place, resize and add widgets anywhere from a rich library. Light / dark themes with an accent picker, organisable navigation, English & Italian.",
  },
];

const stats = [
  { value: 8, label: "Account types" },
  { value: 5, label: "Report types" },
  { value: 4, label: "Import formats", suffix: "+" },
  { value: 100, label: "Your data", suffix: "%" },
];

const shots = [
  { src: "shots/dashboard.png", cap: "A free-form, customisable dashboard" },
  { src: "shots/transactions.png", cap: "A fast, filterable register" },
  { src: "shots/reports.png", cap: "Interactive reports & charts" },
];
---

<Layout page="home">
  <!-- Hero -->
  <section class="hero" id="hero">
    <div class="hero-bg" aria-hidden="true">
      <span class="blob b1"></span><span class="blob b2"></span><span class="blob b3"></span>
    </div>
    <div class="spotlight" id="spotlight" aria-hidden="true"></div>
    <div class="hero-inner">
      <img class="hero-logo float" src={asset("logo.svg")} alt="CloudBank logo" width="96" height="96" />
      <h1 class="reveal">Your money, <span class="grad">self-hosted</span>.</h1>
      <p class="lead reveal">
        CloudBank is a free, web-based personal finance manager — a from-scratch web port of the
        excellent <a href={HOMEBANK} target="_blank" rel="noopener">HomeBank</a> desktop app. One
        Docker container, your data on a volume you control.
      </p>
      <div class="hero-cta reveal">
        <a class="btn primary magnetic" href={asset("download")}>Get started</a>
        <a class="btn magnetic" href={REPO} target="_blank" rel="noopener">View on GitHub</a>
        <a class="btn donate magnetic" href={asset("donate")}>Donate</a>
      </div>
      <p class="badges reveal">
        <span>AGPL-3.0</span><span>Single container</span><span>SQLite</span><span>No tracking</span>
      </p>
      <div class="stats reveal" id="stats">
        {
          stats.map((s) => (
            <div class="stat">
              <b class="count" data-count={s.value} data-suffix={s.suffix ?? ""}>
                0{s.suffix ?? ""}
              </b>
              <small>{s.label}</small>
            </div>
          ))
        }
      </div>
    </div>
    <a class="scroll-hint" href="#preview" aria-label="Scroll down"><span></span></a>
  </section>

  <!-- Screenshots -->
  <section class="preview section" id="preview">
    <h2 class="reveal" style="text-align:center">See it in action</h2>
    <div class="gallery">
      {
        shots.map((s) => (
          <figure class="gframe reveal">
            <img class="shot" src={asset(s.src)} alt={s.cap} loading="lazy" />
            <figcaption class="preview-cap">{s.cap}</figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <!-- Features -->
  <section class="section" id="features">
    <h2 class="reveal" style="text-align:center">Everything HomeBank does — in your browser</h2>
    <p class="section-lead reveal" style="text-align:center">
      Feature parity with the desktop app, rethought for the web and the cloud.
    </p>
    <div class="grid">
      {
        features.map((f, i) => (
          <article class="feature reveal" style={`--i:${i}`}>
            <div class="feature-icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- HomeBank credit -->
  <section id="homebank" class="section split">
    <div class="reveal">
      <h2>Inspired by HomeBank</h2>
      <p>
        CloudBank exists because <a href={HOMEBANK} target="_blank" rel="noopener">HomeBank</a> is a
        wonderful, time-proven desktop app — but it is desktop-only. CloudBank brings the same
        workflow to the web while keeping your data yours.
      </p>
      <p class="muted">
        CloudBank is an <strong>independent, clean-room reimplementation</strong>. It copies no
        HomeBank source code; the original is referenced only for its documented behaviour and file
        formats, and CloudBank tracks parity with current and future HomeBank releases. Released
        under the AGPL-3.0 (HomeBank is GPL-2+).
      </p>
      <a class="btn magnetic" href={HOMEBANK} target="_blank" rel="noopener">Visit HomeBank →</a>
    </div>
    <div class="quote-card reveal">
      <p class="quote">“Native <code>.xhb</code> import &amp; export”</p>
      <p>
        Already using HomeBank? Upload your <code>.xhb</code> file and CloudBank recreates the whole
        wallet — accounts, payees, categories, transactions, transfers, schedules, budgets — to the
        cent. Export back to <code>.xhb</code> any time.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section start" style="text-align:center">
    <h2 class="reveal">Self-host in one command</h2>
    <p class="section-lead reveal">
      One Docker container, no external database. Your data lives in a volume you control.
    </p>
    <div class="hero-cta reveal" style="justify-content:center">
      <a class="btn primary magnetic" href={asset("download")}>Download &amp; install</a>
      <a class="btn magnetic" href={REPO} target="_blank" rel="noopener">Star on GitHub ★</a>
    </div>
  </section>
</Layout>
