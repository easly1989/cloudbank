---
// CloudBank — animated, interactive one-page landing site (GitHub Pages).
const base = import.meta.env.BASE_URL; // e.g. "/cloudbank" or "/cloudbank/"
const asset = (p: string) => `${base.replace(/\/$/, "")}/${p.replace(/^\//, "")}`;

const REPO = "https://github.com/easly1989/cloudbank";
const DONATE = "https://paypal.me/carloruggiero";
const HOMEBANK = "https://www.gethomebank.org/";
const AUTHOR = "https://github.com/easly1989";
const README = `${REPO}#quick-start`;

const features = [
  {
    icon: "🏦",
    title: "Every account type",
    body: "Bank, cash, checking, savings, credit card, liability, asset and investment accounts — each with its own currency and the full set of HomeBank flags.",
  },
  {
    icon: "📒",
    title: "A powerful register",
    body: "Running balances, rich filtering, 12 payment types, the cleared/reconciled lifecycle, category splits, tags, bulk edit and duplicate detection.",
  },
  {
    icon: "🔁",
    title: "Schedules & automation",
    body: "Scheduled transactions with automatic posting, reusable templates, and assignment rules that auto-categorise as you go.",
  },
  {
    icon: "📊",
    title: "Budgets & reports",
    body: "Budgets plus Statistics, Trend, Balance, Budget and Vehicle-cost reports — interactive charts with CSV / PNG export.",
  },
  {
    icon: "📥",
    title: "Import & export",
    body: "Native HomeBank .xhb import and export, plus QIF, OFX/QFX and CSV — with a guided import assistant.",
  },
  {
    icon: "🌍",
    title: "Multi-currency",
    body: "Per-account currencies with manual or online (ECB / frankfurter.app) exchange rates and full conversion in reports.",
  },
  {
    icon: "👥",
    title: "Multi-user & private",
    body: "Admin-managed users, each with isolated wallets. Your data lives in a SQLite file on a volume you control — nothing leaves your server.",
  },
  {
    icon: "🎨",
    title: "Made yours",
    body: "Responsive UI, light / dark themes with an accent picker, a customisable dashboard, organisable navigation, English & Italian.",
  },
];

const stats = [
  { value: 8, label: "Account types" },
  { value: 5, label: "Report types" },
  { value: 4, label: "Import formats", suffix: "+" },
  { value: 100, label: "Your data", suffix: "%" },
];

// Accent presets the on-page picker offers (mirrors the app's accent feature).
const accents = [
  { name: "teal", c: ["#12b886", "#15aabf", "#4dabf7"] },
  { name: "blue", c: ["#4dabf7", "#3b82f6", "#7048e8"] },
  { name: "violet", c: ["#7048e8", "#9775fa", "#e64980"] },
  { name: "grape", c: ["#e64980", "#f06595", "#ff922b"] },
  { name: "orange", c: ["#ff922b", "#fab005", "#40c057"] },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={asset("favicon.svg")} />
    <title>CloudBank — your money, self-hosted</title>
    <meta
      name="description"
      content="CloudBank is a free, self-hosted, web-based personal finance manager — a from-scratch web port of HomeBank. One Docker container, your data on your server."
    />
    <meta property="og:title" content="CloudBank — your money, self-hosted" />
    <meta
      property="og:description"
      content="A free, self-hosted web port of HomeBank. Accounts, register, schedules, budgets, rich reports and native .xhb import — in one Docker container."
    />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0b1120" />
    <!-- Apply the saved theme/accent and flag JS before paint (no flash, and
         reveal content stays hidden only when JS is present to reveal it). -->
    <script is:inline>
      (function () {
        const d = document.documentElement;
        d.classList.add("js");
        try {
          const t = localStorage.getItem("cb-site-theme");
          if (t) d.setAttribute("data-theme", t);
          const a = localStorage.getItem("cb-site-accent");
          if (a) {
            const [c1, c2, c3] = JSON.parse(a);
            d.style.setProperty("--accent", c1);
            d.style.setProperty("--accent-2", c2);
            d.style.setProperty("--accent-3", c3);
          }
        } catch (e) {
          /* ignore */
        }
      })();
    </script>
  </head>
  <body>
    <div class="progress" aria-hidden="true"><span id="progress-bar"></span></div>

    <header class="nav">
      <a class="brand" href="#top" aria-label="CloudBank home">
        <img src={asset("logo.svg")} alt="" width="30" height="30" />
        <span>CloudBank</span>
      </a>
      <nav class="nav-links" id="nav-links">
        <a href="#features" data-section="features">Features</a>
        <a href="#homebank" data-section="homebank">HomeBank</a>
        <a href="#start" data-section="start">Self-host</a>
        <div class="accent-picker" role="group" aria-label="Accent colour">
          {
            accents.map((a) => (
              <button
                type="button"
                class="swatch"
                data-accent={JSON.stringify(a.c)}
                style={`--sw:${a.c[0]}`}
                aria-label={`Accent ${a.name}`}
                title={`Accent ${a.name}`}
              />
            ))
          }
        </div>
        <button type="button" id="theme-toggle" class="icon-btn" aria-label="Toggle light / dark">
          <span class="theme-icon" aria-hidden="true"></span>
        </button>
        <a class="ghost" href={REPO} target="_blank" rel="noopener">GitHub</a>
        <a class="cta" href={DONATE} target="_blank" rel="noopener">Donate ♥</a>
      </nav>
    </header>

    <main id="top">
      <!-- Hero -->
      <section class="hero" id="hero">
        <div class="hero-bg" aria-hidden="true">
          <span class="blob b1"></span><span class="blob b2"></span><span class="blob b3"></span>
        </div>
        <div class="spotlight" id="spotlight" aria-hidden="true"></div>
        <div class="hero-inner">
          <img
            class="hero-logo float"
            src={asset("logo.svg")}
            alt="CloudBank logo"
            width="96"
            height="96"
          />
          <h1 class="reveal">Your money, <span class="grad">self-hosted</span>.</h1>
          <p class="lead reveal">
            CloudBank is a free, web-based personal finance manager — a from-scratch web port of the
            excellent <a href={HOMEBANK} target="_blank" rel="noopener">HomeBank</a> desktop app. One
            Docker container, your data on a volume you control.
          </p>
          <div class="hero-cta reveal">
            <a class="btn primary magnetic" href="#start">Get started</a>
            <a class="btn magnetic" href={REPO} target="_blank" rel="noopener">View on GitHub</a>
            <a class="btn donate magnetic" href={DONATE} target="_blank" rel="noopener">Donate</a>
          </div>
          <p class="badges reveal">
            <span>AGPL-3.0</span><span>Single container</span><span>SQLite</span><span
              >No tracking</span
            >
          </p>

          <div class="stats reveal" id="stats">
            {
              stats.map((s) => (
                <div class="stat">
                  <b class="count" data-count={s.value} data-suffix={s.suffix ?? ""}>
                    0
                  </b>
                  <small>{s.label}</small>
                </div>
              ))
            }
          </div>
        </div>
        <a class="scroll-hint" href="#preview" aria-label="Scroll down"><span></span></a>
      </section>

      <!-- Live preview mockup -->
      <section class="preview reveal" id="preview">
        <div class="window tilt" id="preview-window">
          <div class="window-bar">
            <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
            <span class="url">localhost:8080</span>
          </div>
          <div class="window-body">
            <aside class="mock-nav">
              <span class="mock-logo"></span>
              <i class="active"></i><i></i><i></i><i></i><i></i><i></i>
            </aside>
            <div class="mock-main">
              <div class="mock-row">
                <div class="mock-card kpi"><b data-kpi="0">€ 12,480</b><small>Net worth</small></div>
                <div class="mock-card kpi"><b data-kpi="1">€ 2,310</b><small>This month</small></div>
                <div class="mock-card kpi"><b data-kpi="2">4</b><small>Accounts</small></div>
              </div>
              <div class="mock-row">
                <div class="mock-card chart">
                  <span class="bars" id="mock-bars"
                    ><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></span
                  >
                </div>
                <div class="mock-card donut"><span class="ring"></span></div>
              </div>
            </div>
          </div>
        </div>
        <p class="preview-cap">A live peek at the dashboard — customisable, themeable, yours.</p>
      </section>

      <!-- Features -->
      <section id="features" class="section">
        <h2 class="reveal">Everything HomeBank does, in your browser</h2>
        <p class="section-lead reveal">
          Built for feature parity with HomeBank — reachable from any device, with the data staying
          on your own server.
        </p>
        <div class="grid">
          {
            features.map((f, i) => (
              <article class="feature reveal" style={`--i:${i}`}>
                <div class="feature-icon">{f.icon}</div>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- HomeBank credit -->
      <section id="homebank" class="section split">
        <div class="reveal">
          <h2>Inspired by HomeBank</h2>
          <p>
            CloudBank exists because <a href={HOMEBANK} target="_blank" rel="noopener">HomeBank</a> is
            a wonderful, time-proven desktop app — but it is desktop-only. CloudBank brings the same
            workflow to the web while keeping your data yours.
          </p>
          <p class="muted">
            CloudBank is an <strong>independent, clean-room reimplementation</strong>. It copies no
            HomeBank source code; the original is referenced only for its documented behaviour and
            file formats, and CloudBank tracks parity with current and future HomeBank releases.
            Released under the AGPL-3.0 (HomeBank is GPL-2+).
          </p>
          <a class="btn magnetic" href={HOMEBANK} target="_blank" rel="noopener">Visit HomeBank →</a>
        </div>
        <div class="quote-card reveal">
          <p class="quote">“Native <code>.xhb</code> import &amp; export”</p>
          <p>
            Already using HomeBank? Upload your <code>.xhb</code> file and CloudBank recreates the whole
            wallet — accounts, payees, categories, transactions, transfers, schedules, budgets — to the
            cent. Export back to <code>.xhb</code> any time.
          </p>
        </div>
      </section>

      <!-- The mind behind it -->
      <section id="author" class="section author reveal">
        <h2>The mind behind it</h2>
        <div class="author-card">
          <div class="avatar">CR</div>
          <div>
            <h3>Carlo Ruggiero</h3>
            <p>
              CloudBank is built and maintained by Carlo Ruggiero — a HomeBank user who wanted the
              same trusted workflow on every device, self-hosted and private. It's an open-source
              labour of love; contributions and feedback are welcome.
            </p>
            <div class="author-links">
              <a class="btn small magnetic" href={AUTHOR} target="_blank" rel="noopener"
                >GitHub @easly1989</a
              >
              <a class="btn small donate magnetic" href={DONATE} target="_blank" rel="noopener"
                >Buy me a coffee ♥</a
              >
            </div>
          </div>
        </div>
      </section>

      <!-- Get started -->
      <section id="start" class="section start">
        <h2 class="reveal">Self-host in one command</h2>
        <p class="section-lead reveal">
          You only need Docker with the Compose plugin. Your data lives in the
          <code>cloudbank-data</code> volume — back it up by copying it, or from inside the app.
        </p>
        <pre class="code reveal"><code>{`services:
  cloudbank:
    image: ghcr.io/easly1989/cloudbank:main
    container_name: cloudbank
    restart: unless-stopped
    ports:
      - "8080:8080"
    environment:
      CB_SECURE_COOKIES: "false"   # behind HTTPS? set to "true"
    volumes:
      - cloudbank-data:/data

volumes:
  cloudbank-data:`}</code></pre>
        <p class="run reveal">
          <code>docker compose up -d</code> &nbsp;→&nbsp; open <code>http://localhost:8080</code> and
          complete the first-run admin setup.
        </p>
        <div class="hero-cta reveal">
          <a class="btn primary magnetic" href={README} target="_blank" rel="noopener"
            >Full install guide</a
          >
          <a class="btn magnetic" href={REPO} target="_blank" rel="noopener">Star on GitHub ★</a>
          <a class="btn donate magnetic" href={DONATE} target="_blank" rel="noopener">Donate</a>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <a class="brand" href="#top">
          <img src={asset("logo.svg")} alt="" width="22" height="22" />
          <span>CloudBank</span>
        </a>
        <nav class="footer-links">
          <a href={REPO} target="_blank" rel="noopener">GitHub</a>
          <a href={`${REPO}/issues`} target="_blank" rel="noopener">Issues</a>
          <a href={HOMEBANK} target="_blank" rel="noopener">HomeBank</a>
          <a href={DONATE} target="_blank" rel="noopener">Donate</a>
        </nav>
        <p class="copy">
          Free &amp; open source under the AGPL-3.0 · A clean-room web port of HomeBank · Not
          affiliated with HomeBank.
        </p>
      </div>
    </footer>

    <script>
      const root = document.documentElement;
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // --- Reveal on scroll (with per-card stagger via --i) --------------------
      const reveals = document.querySelectorAll<HTMLElement>(".reveal");
      if (reduce || !("IntersectionObserver" in window)) {
        reveals.forEach((el) => el.classList.add("in-view"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("in-view");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
        );
        reveals.forEach((el) => io.observe(el));
      }

      // --- Scroll progress bar -------------------------------------------------
      const bar = document.getElementById("progress-bar");
      const onScroll = () => {
        const h = document.documentElement;
        const max = h.scrollHeight - h.clientHeight;
        const p = max > 0 ? (h.scrollTop / max) * 100 : 0;
        if (bar) bar.style.width = p + "%";
      };
      document.addEventListener("scroll", onScroll, { passive: true });
      onScroll();

      // --- Active section highlight in the nav ---------------------------------
      const links = Array.from(
        document.querySelectorAll<HTMLAnchorElement>("#nav-links a[data-section]"),
      );
      const sections = links
        .map((l) => document.getElementById(l.dataset.section!))
        .filter(Boolean) as HTMLElement[];
      if ("IntersectionObserver" in window && sections.length) {
        const so = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                const id = e.target.id;
                links.forEach((l) => l.classList.toggle("active", l.dataset.section === id));
              }
            }
          },
          { threshold: 0.5 },
        );
        sections.forEach((s) => so.observe(s));
      }

      // --- Count-up stats ------------------------------------------------------
      const counters = document.querySelectorAll<HTMLElement>(".count");
      const runCount = (el: HTMLElement) => {
        const target = Number(el.dataset.count || "0");
        const suffix = el.dataset.suffix || "";
        if (reduce) {
          el.textContent = target + suffix;
          return;
        }
        const start = performance.now();
        const dur = 1100;
        const tick = (now: number) => {
          const t = Math.min(1, (now - start) / dur);
          const eased = 1 - Math.pow(1 - t, 3);
          el.textContent = Math.round(target * eased) + suffix;
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };
      if ("IntersectionObserver" in window && counters.length) {
        const co = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                runCount(e.target as HTMLElement);
                co.unobserve(e.target);
              }
            }
          },
          { threshold: 0.6 },
        );
        counters.forEach((c) => co.observe(c));
      } else {
        counters.forEach(runCount);
      }

      // --- Live-feeling preview (cycling KPIs + bars) --------------------------
      if (!reduce) {
        const kpis = document.querySelectorAll<HTMLElement>("[data-kpi]");
        const netSeq = ["€ 12,480", "€ 12,905", "€ 13,140", "€ 12,760"];
        const monSeq = ["€ 2,310", "€ 1,980", "€ 2,640", "€ 2,415"];
        const bars = document.querySelectorAll<HTMLElement>("#mock-bars i");
        let step = 0;
        const cycle = () => {
          step++;
          const k0 = kpis[0],
            k1 = kpis[1];
          if (k0) k0.textContent = netSeq[step % netSeq.length];
          if (k1) k1.textContent = monSeq[step % monSeq.length];
          bars.forEach((b) => (b.style.height = 30 + Math.round(Math.random() * 65) + "%"));
        };
        setInterval(cycle, 2600);
      }

      // --- Hero pointer spotlight (desktop, motion-on) -------------------------
      const spotlight = document.getElementById("spotlight");
      const hero = document.getElementById("hero");
      if (spotlight && hero && !reduce && window.matchMedia("(pointer: fine)").matches) {
        hero.addEventListener("pointermove", (e) => {
          const r = hero.getBoundingClientRect();
          spotlight.style.setProperty("--mx", e.clientX - r.left + "px");
          spotlight.style.setProperty("--my", e.clientY - r.top + "px");
          spotlight.style.opacity = "1";
        });
        hero.addEventListener("pointerleave", () => (spotlight.style.opacity = "0"));
      }

      // --- Magnetic buttons ----------------------------------------------------
      if (!reduce && window.matchMedia("(pointer: fine)").matches) {
        document.querySelectorAll<HTMLElement>(".magnetic").forEach((el) => {
          el.addEventListener("pointermove", (e) => {
            const r = el.getBoundingClientRect();
            const mx = e.clientX - r.left - r.width / 2;
            const my = e.clientY - r.top - r.height / 2;
            el.style.transform = `translate(${mx * 0.18}px, ${my * 0.28}px)`;
          });
          el.addEventListener("pointerleave", () => (el.style.transform = ""));
        });
      }

      // --- Theme toggle --------------------------------------------------------
      const themeBtn = document.getElementById("theme-toggle");
      const currentTheme = () => {
        const set = root.getAttribute("data-theme");
        if (set) return set;
        return window.matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";
      };
      themeBtn?.addEventListener("click", () => {
        const next = currentTheme() === "dark" ? "light" : "dark";
        root.setAttribute("data-theme", next);
        try {
          localStorage.setItem("cb-site-theme", next);
        } catch (e) {
          /* ignore */
        }
      });

      // --- Accent picker (recolours the page; mirrors the app) -----------------
      document.querySelectorAll<HTMLButtonElement>(".swatch").forEach((sw) => {
        sw.addEventListener("click", () => {
          try {
            const c = JSON.parse(sw.dataset.accent!);
            root.style.setProperty("--accent", c[0]);
            root.style.setProperty("--accent-2", c[1]);
            root.style.setProperty("--accent-3", c[2]);
            localStorage.setItem("cb-site-accent", JSON.stringify(c));
          } catch (e) {
            /* ignore */
          }
        });
      });
    </script>

    <style is:global>
      :root {
        --bg: #0b1120;
        --bg-2: #0f1a30;
        --panel: #131f38;
        --panel-2: #18253f;
        --border: #243352;
        --text: #e8eef7;
        --muted: #9fb0c9;
        --shadow: rgba(0, 0, 0, 0.5);
        --accent: #12b886;
        --accent-2: #15aabf;
        --accent-3: #4dabf7;
        --on-accent: #04241b;
        --radius: 16px;
        --maxw: 1080px;
        color-scheme: dark;
      }
      /* Light theme — chosen explicitly, or by system when nothing is saved. */
      :root[data-theme="light"] {
        --bg: #f6f8fc;
        --bg-2: #eef2f9;
        --panel: #ffffff;
        --panel-2: #f3f6fb;
        --border: #dde4ef;
        --text: #14233c;
        --muted: #5a6b86;
        --shadow: rgba(20, 35, 60, 0.14);
        color-scheme: light;
      }
      @media (prefers-color-scheme: light) {
        :root:not([data-theme]) {
          --bg: #f6f8fc;
          --bg-2: #eef2f9;
          --panel: #ffffff;
          --panel-2: #f3f6fb;
          --border: #dde4ef;
          --text: #14233c;
          --muted: #5a6b86;
          --shadow: rgba(20, 35, 60, 0.14);
          color-scheme: light;
        }
      }

      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family:
          system-ui,
          -apple-system,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        transition:
          background 0.4s ease,
          color 0.4s ease;
        overflow-x: hidden;
      }
      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      h1,
      h2,
      h3 {
        line-height: 1.15;
        margin: 0 0 0.5em;
      }
      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        background: color-mix(in srgb, var(--text) 8%, transparent);
        padding: 0.1em 0.4em;
        border-radius: 6px;
        font-size: 0.92em;
      }

      /* Scroll progress */
      .progress {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        z-index: 60;
        background: transparent;
      }
      .progress span {
        display: block;
        height: 100%;
        width: 0;
        background: linear-gradient(90deg, var(--accent), var(--accent-2), var(--accent-3));
      }

      /* Nav */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.7rem clamp(1rem, 4vw, 2.5rem);
        background: color-mix(in srgb, var(--bg) 72%, transparent);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-weight: 800;
        font-size: 1.1rem;
        color: var(--text);
      }
      .brand:hover {
        text-decoration: none;
      }
      .brand img {
        transition: transform 0.4s ease;
      }
      .brand:hover img {
        transform: rotate(-8deg) scale(1.08);
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: clamp(0.4rem, 1.6vw, 1.2rem);
      }
      .nav-links > a {
        position: relative;
        color: var(--muted);
        font-weight: 600;
        font-size: 0.95rem;
      }
      .nav-links > a:hover {
        color: var(--text);
        text-decoration: none;
      }
      .nav-links > a[data-section]::after {
        content: "";
        position: absolute;
        left: 0;
        right: 100%;
        bottom: -4px;
        height: 2px;
        background: var(--accent);
        transition: right 0.25s ease;
      }
      .nav-links > a[data-section]:hover::after,
      .nav-links > a.active::after {
        right: 0;
      }
      .nav-links > a.active {
        color: var(--text);
      }
      .nav-links .ghost {
        color: var(--text);
      }
      .nav-links .cta {
        color: var(--on-accent);
        background: var(--accent);
        padding: 0.4rem 0.85rem;
        border-radius: 999px;
      }
      .nav-links .cta:hover {
        filter: brightness(1.08);
        text-decoration: none;
      }
      .accent-picker {
        display: flex;
        gap: 6px;
        padding: 0 0.2rem;
      }
      .swatch {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        border: 2px solid transparent;
        background: var(--sw);
        cursor: pointer;
        padding: 0;
        transition: transform 0.15s ease;
      }
      .swatch:hover {
        transform: scale(1.25);
        border-color: var(--text);
      }
      .icon-btn {
        display: inline-grid;
        place-items: center;
        width: 32px;
        height: 32px;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: var(--panel-2);
        color: var(--text);
        cursor: pointer;
      }
      .icon-btn:hover {
        border-color: var(--accent);
      }
      .theme-icon {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: var(--text);
        box-shadow: inset -5px -3px 0 0 var(--panel-2);
      }
      :root[data-theme="light"] .theme-icon,
      :root:not([data-theme]) .theme-icon {
        box-shadow: none;
        background: radial-gradient(circle, var(--accent) 40%, transparent 42%),
          conic-gradient(var(--text) 0 0);
        -webkit-mask: radial-gradient(circle 8px at center, #000 98%, transparent);
        mask: radial-gradient(circle 8px at center, #000 98%, transparent);
      }
      @media (max-width: 760px) {
        .nav-links > a[data-section] {
          display: none;
        }
      }
      @media (max-width: 540px) {
        .accent-picker {
          display: none;
        }
      }

      /* Hero */
      .hero {
        position: relative;
        overflow: hidden;
        text-align: center;
        padding: clamp(3rem, 8vw, 6rem) 1.25rem clamp(2rem, 5vw, 3.5rem);
      }
      .hero-bg {
        position: absolute;
        inset: 0;
        pointer-events: none;
      }
      .blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(60px);
        opacity: 0.55;
        animation: drift 16s ease-in-out infinite alternate;
      }
      .blob.b1 {
        width: 42vw;
        height: 42vw;
        left: 8%;
        top: -8%;
        background: var(--accent);
      }
      .blob.b2 {
        width: 38vw;
        height: 38vw;
        right: 6%;
        top: -4%;
        background: var(--accent-3);
        animation-delay: -4s;
      }
      .blob.b3 {
        width: 30vw;
        height: 30vw;
        left: 40%;
        top: 40%;
        background: var(--accent-2);
        animation-delay: -8s;
      }
      @keyframes drift {
        from {
          transform: translate3d(-3%, -2%, 0) scale(1);
        }
        to {
          transform: translate3d(4%, 3%, 0) scale(1.12);
        }
      }
      .spotlight {
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.3s ease;
        background: radial-gradient(
          240px circle at var(--mx, 50%) var(--my, 50%),
          color-mix(in srgb, var(--accent) 30%, transparent),
          transparent 70%
        );
      }
      .hero-inner {
        position: relative;
        max-width: 820px;
        margin: 0 auto;
      }
      .hero-logo {
        filter: drop-shadow(0 10px 30px color-mix(in srgb, var(--accent) 45%, transparent));
      }
      .float {
        animation: float 6s ease-in-out infinite;
      }
      @keyframes float {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-10px);
        }
      }
      .hero h1 {
        font-size: clamp(2.4rem, 7vw, 4rem);
        margin-top: 1rem;
        letter-spacing: -0.02em;
      }
      .grad {
        background: linear-gradient(100deg, var(--accent), var(--accent-2) 50%, var(--accent-3));
        background-size: 200% auto;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        animation: shine 6s linear infinite;
      }
      @keyframes shine {
        to {
          background-position: 200% center;
        }
      }
      .lead {
        font-size: clamp(1.05rem, 2.4vw, 1.3rem);
        color: var(--muted);
        max-width: 640px;
        margin: 0 auto 1.6rem;
      }
      .hero-cta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }
      .badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: center;
        margin-top: 1.8rem;
      }
      .badges span {
        font-size: 0.8rem;
        color: var(--muted);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.25rem 0.7rem;
      }
      .stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0.75rem;
        max-width: 560px;
        margin: 2.4rem auto 0;
      }
      .stat {
        background: color-mix(in srgb, var(--panel) 70%, transparent);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.8rem 0.4rem;
      }
      .stat b {
        display: block;
        font-size: clamp(1.3rem, 3.5vw, 1.9rem);
        color: var(--accent);
        line-height: 1.1;
      }
      .stat small {
        color: var(--muted);
        font-size: 0.78rem;
      }
      @media (max-width: 520px) {
        .stats {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      .scroll-hint {
        position: absolute;
        bottom: 0.6rem;
        left: 50%;
        transform: translateX(-50%);
        width: 24px;
        height: 38px;
        border: 2px solid var(--muted);
        border-radius: 999px;
        opacity: 0.6;
      }
      .scroll-hint span {
        position: absolute;
        left: 50%;
        top: 7px;
        width: 4px;
        height: 7px;
        margin-left: -2px;
        border-radius: 2px;
        background: var(--muted);
        animation: wheel 1.6s ease-in-out infinite;
      }
      @keyframes wheel {
        0% {
          opacity: 0;
          transform: translateY(0);
        }
        40% {
          opacity: 1;
        }
        100% {
          opacity: 0;
          transform: translateY(12px);
        }
      }

      /* Buttons */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.7rem 1.25rem;
        border-radius: 999px;
        font-weight: 700;
        font-size: 0.98rem;
        color: var(--text);
        background: var(--panel-2);
        border: 1px solid var(--border);
        transition:
          transform 0.12s ease,
          filter 0.15s ease,
          box-shadow 0.15s ease;
      }
      .btn:hover {
        text-decoration: none;
        filter: brightness(1.08);
        box-shadow: 0 10px 24px var(--shadow);
      }
      .btn.primary {
        background: linear-gradient(100deg, var(--accent), var(--accent-2));
        color: var(--on-accent);
        border-color: transparent;
      }
      .btn.donate {
        background: transparent;
        border-color: var(--accent);
        color: var(--accent);
      }
      .btn.small {
        padding: 0.5rem 0.95rem;
        font-size: 0.9rem;
      }

      /* Preview window */
      .preview {
        max-width: var(--maxw);
        margin: -0.5rem auto 0;
        padding: 0 1.25rem;
        text-align: center;
      }
      .window {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--panel);
        box-shadow: 0 30px 80px var(--shadow);
        overflow: hidden;
        text-align: left;
        transition: transform 0.3s ease;
      }
      .tilt:hover {
        transform: perspective(1200px) rotateX(1.4deg) translateY(-4px);
      }
      .window-bar {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.6rem 0.9rem;
        background: var(--panel-2);
        border-bottom: 1px solid var(--border);
      }
      .dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        display: inline-block;
      }
      .dot.r {
        background: #ff5f57;
      }
      .dot.y {
        background: #febc2e;
      }
      .dot.g {
        background: #28c840;
      }
      .url {
        margin-left: 0.6rem;
        font-size: 0.8rem;
        color: var(--muted);
      }
      .window-body {
        display: grid;
        grid-template-columns: 76px 1fr;
        min-height: 320px;
      }
      .mock-nav {
        background: var(--bg-2);
        border-right: 1px solid var(--border);
        padding: 0.9rem 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.7rem;
      }
      .mock-logo {
        width: 26px;
        height: 26px;
        border-radius: 8px;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        margin-bottom: 0.6rem;
      }
      .mock-nav i {
        width: 40px;
        height: 9px;
        border-radius: 5px;
        background: var(--border);
      }
      .mock-nav i.active {
        background: var(--accent);
      }
      .mock-main {
        padding: 1.1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .mock-row {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(3, 1fr);
      }
      .mock-row:nth-child(2) {
        grid-template-columns: 2fr 1fr;
      }
      .mock-card {
        background: var(--panel-2);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.9rem;
      }
      .mock-card.kpi b {
        font-size: 1.25rem;
        display: block;
        color: var(--text);
        transition: color 0.3s ease;
      }
      .mock-card.kpi small {
        color: var(--muted);
      }
      .mock-card.chart {
        min-height: 130px;
        display: flex;
        align-items: flex-end;
      }
      .bars {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        width: 100%;
        height: 100px;
      }
      .bars i {
        flex: 1;
        background: linear-gradient(180deg, var(--accent), var(--accent-2));
        border-radius: 4px 4px 0 0;
        height: 50%;
        transition: height 0.7s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .bars i:nth-child(1) {
        height: 40%;
      }
      .bars i:nth-child(2) {
        height: 70%;
      }
      .bars i:nth-child(3) {
        height: 55%;
      }
      .bars i:nth-child(4) {
        height: 85%;
      }
      .bars i:nth-child(5) {
        height: 60%;
      }
      .bars i:nth-child(6) {
        height: 95%;
      }
      .bars i:nth-child(7) {
        height: 50%;
      }
      .bars i:nth-child(8) {
        height: 75%;
      }
      .mock-card.donut {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .ring {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        background: conic-gradient(
          var(--accent) 0 38%,
          var(--accent-2) 38% 62%,
          var(--accent-3) 62% 82%,
          var(--border) 82% 100%
        );
        -webkit-mask: radial-gradient(circle 30px at center, transparent 98%, #000 100%);
        mask: radial-gradient(circle 30px at center, transparent 98%, #000 100%);
      }
      .preview-cap {
        color: var(--muted);
        font-size: 0.9rem;
        margin-top: 1rem;
      }

      /* Sections */
      .section {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: clamp(3.5rem, 8vw, 6rem) 1.25rem;
      }
      .section h2 {
        font-size: clamp(1.7rem, 4vw, 2.4rem);
        text-align: center;
        letter-spacing: -0.01em;
      }
      .section-lead {
        text-align: center;
        color: var(--muted);
        max-width: 640px;
        margin: 0 auto 2.5rem;
      }
      .grid {
        display: grid;
        gap: 1.1rem;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }
      .feature {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.4rem;
        transition:
          transform 0.2s ease,
          border-color 0.2s ease,
          box-shadow 0.2s ease;
      }
      .feature:hover {
        transform: translateY(-6px);
        border-color: var(--accent);
        box-shadow: 0 16px 36px var(--shadow);
      }
      .feature-icon {
        font-size: 1.7rem;
        margin-bottom: 0.4rem;
        transition: transform 0.2s ease;
      }
      .feature:hover .feature-icon {
        transform: scale(1.18) rotate(-6deg);
      }
      .feature h3 {
        font-size: 1.1rem;
      }
      .feature p {
        color: var(--muted);
        margin: 0;
        font-size: 0.96rem;
      }

      .split {
        display: grid;
        gap: 2rem;
        grid-template-columns: 1.1fr 0.9fr;
        align-items: center;
      }
      .split h2 {
        text-align: left;
      }
      .split p {
        color: var(--text);
      }
      .split .muted {
        color: var(--muted);
        font-size: 0.95rem;
      }
      .quote-card {
        background: linear-gradient(160deg, var(--panel), var(--panel-2));
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.6rem;
      }
      .quote {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--accent);
        margin-top: 0;
      }
      @media (max-width: 760px) {
        .split {
          grid-template-columns: 1fr;
        }
      }

      /* Author */
      .author h2 {
        margin-bottom: 1.5rem;
      }
      .author-card {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1.4rem;
        align-items: center;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.6rem;
      }
      .avatar {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-weight: 800;
        font-size: 1.6rem;
        color: var(--on-accent);
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
      }
      .author-card h3 {
        margin-bottom: 0.3rem;
      }
      .author-card p {
        color: var(--muted);
        margin-top: 0;
      }
      .author-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 0.4rem;
      }
      @media (max-width: 560px) {
        .author-card {
          grid-template-columns: 1fr;
          text-align: center;
          justify-items: center;
        }
      }

      /* Start */
      .start {
        text-align: center;
      }
      .code {
        text-align: left;
        max-width: 640px;
        margin: 0 auto 1.2rem;
        background: color-mix(in srgb, var(--text) 92%, #07101f);
        color: #cfe6dd;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.1rem 1.3rem;
        overflow-x: auto;
        font-size: 0.88rem;
        line-height: 1.5;
      }
      :root[data-theme="light"] .code,
      :root:not([data-theme]) .code {
        background: #0c1626;
      }
      .code code {
        background: none;
        padding: 0;
        color: inherit;
      }
      .run {
        color: var(--muted);
      }

      /* Footer */
      .footer {
        border-top: 1px solid var(--border);
        background: var(--bg-2);
      }
      .footer-inner {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 2rem 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.8rem;
        text-align: center;
      }
      .footer-links {
        display: flex;
        gap: 1.2rem;
        flex-wrap: wrap;
        justify-content: center;
      }
      .footer-links a {
        color: var(--muted);
        font-weight: 600;
      }
      .copy {
        color: var(--muted);
        font-size: 0.85rem;
        margin: 0;
      }

      /* Reveal animation — only hide when JS is present to reveal it again. */
      .js .reveal {
        opacity: 0;
        transform: translateY(24px);
        transition:
          opacity 0.7s ease,
          transform 0.7s ease;
      }
      .js .feature.reveal {
        transition-delay: calc(var(--i, 0) * 70ms);
      }
      .js .reveal.in-view {
        opacity: 1;
        transform: none;
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        .js .reveal {
          opacity: 1;
          transform: none;
          transition: none;
        }
        .float,
        .blob,
        .grad,
        .scroll-hint span,
        .bars i {
          animation: none !important;
        }
      }
    </style>
  </body>
</html>
