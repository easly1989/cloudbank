---
// CloudBank — animated one-page landing site (GitHub Pages).
const base = import.meta.env.BASE_URL; // e.g. "/cloudbank" or "/cloudbank/"
// Join the base and a public asset path with exactly one slash, regardless of
// whether BASE_URL carries a trailing slash.
const asset = (p: string) => `${base.replace(/\/$/, "")}/${p.replace(/^\//, "")}`;

const REPO = "https://github.com/easly1989/cloudbank";
const DONATE = "https://paypal.me/carloruggiero";
const HOMEBANK = "https://www.gethomebank.org/";
const AUTHOR = "https://github.com/easly1989";
const README = `${REPO}#quick-start`;

const features = [
  {
    icon: "🏦",
    title: "Every account type",
    body: "Bank, cash, checking, savings, credit card, liability, asset and investment accounts — each with its own currency and the full set of HomeBank flags.",
  },
  {
    icon: "📒",
    title: "A powerful register",
    body: "Running balances, rich filtering, 12 payment types, the cleared/reconciled lifecycle, category splits, tags, bulk edit and duplicate detection.",
  },
  {
    icon: "🔁",
    title: "Schedules & automation",
    body: "Scheduled transactions with automatic posting, reusable templates, and assignment rules that auto-categorise as you go.",
  },
  {
    icon: "📊",
    title: "Budgets & reports",
    body: "Budgets plus Statistics, Trend, Balance, Budget and Vehicle-cost reports — interactive charts with CSV / PNG export.",
  },
  {
    icon: "📥",
    title: "Import & export",
    body: "Native HomeBank .xhb import and export, plus QIF, OFX/QFX and CSV — with a guided import assistant.",
  },
  {
    icon: "🌍",
    title: "Multi-currency",
    body: "Per-account currencies with manual or online (ECB / frankfurter.app) exchange rates and full conversion in reports.",
  },
  {
    icon: "👥",
    title: "Multi-user & private",
    body: "Admin-managed users, each with isolated wallets. Your data lives in a SQLite file on a volume you control — nothing leaves your server.",
  },
  {
    icon: "🎨",
    title: "Made yours",
    body: "Responsive UI, light / dark themes with an accent picker, a customisable dashboard, organisable navigation, English & Italian.",
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={asset("favicon.svg")} />
    <title>CloudBank — your money, self-hosted</title>
    <meta
      name="description"
      content="CloudBank is a free, self-hosted, web-based personal finance manager — a from-scratch web port of HomeBank. One Docker container, your data on your server."
    />
    <meta property="og:title" content="CloudBank — your money, self-hosted" />
    <meta
      property="og:description"
      content="A free, self-hosted web port of HomeBank. Accounts, register, schedules, budgets, rich reports and native .xhb import — in one Docker container."
    />
    <meta property="og:type" content="website" />
    <!-- Flag JS so reveal-on-scroll hides content only when JS can reveal it
         (no-JS / failed-load shows everything). Runs before paint. -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
  </head>
  <body>
    <header class="nav">
      <a class="brand" href="#top" aria-label="CloudBank home">
        <img src={asset("logo.svg")} alt="" width="30" height="30" />
        <span>CloudBank</span>
      </a>
      <nav class="nav-links">
        <a href="#features">Features</a>
        <a href="#homebank">HomeBank</a>
        <a href="#start">Self-host</a>
        <a class="ghost" href={REPO} target="_blank" rel="noopener">GitHub</a>
        <a class="cta" href={DONATE} target="_blank" rel="noopener">Donate ♥</a>
      </nav>
    </header>

    <main id="top">
      <!-- Hero -->
      <section class="hero">
        <div class="hero-bg" aria-hidden="true"></div>
        <div class="hero-inner">
          <img class="hero-logo float" src={asset("logo.svg")} alt="CloudBank logo" width="96" height="96" />
          <h1 class="reveal">Your money, <span class="grad">self-hosted</span>.</h1>
          <p class="lead reveal">
            CloudBank is a free, web-based personal finance manager — a from-scratch web port of the
            excellent <a href={HOMEBANK} target="_blank" rel="noopener">HomeBank</a> desktop app.
            One Docker container, your data on a volume you control.
          </p>
          <div class="hero-cta reveal">
            <a class="btn primary" href="#start">Get started</a>
            <a class="btn" href={REPO} target="_blank" rel="noopener">View on GitHub</a>
            <a class="btn donate" href={DONATE} target="_blank" rel="noopener">Donate</a>
          </div>
          <p class="badges reveal">
            <span>AGPL-3.0</span><span>Single container</span><span>SQLite</span><span>No tracking</span>
          </p>
        </div>
      </section>

      <!-- Preview mockup -->
      <section class="preview reveal" aria-hidden="true">
        <div class="window">
          <div class="window-bar">
            <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
            <span class="url">localhost:8080</span>
          </div>
          <div class="window-body">
            <aside class="mock-nav">
              <span class="mock-logo"></span>
              <i class="active"></i><i></i><i></i><i></i><i></i><i></i>
            </aside>
            <div class="mock-main">
              <div class="mock-row">
                <div class="mock-card kpi"><b>€ 12,480</b><small>Net worth</small></div>
                <div class="mock-card kpi"><b>€ 2,310</b><small>This month</small></div>
                <div class="mock-card kpi"><b>4</b><small>Accounts</small></div>
              </div>
              <div class="mock-row">
                <div class="mock-card chart"><span class="bars"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></span></div>
                <div class="mock-card donut"><span class="ring"></span></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Features -->
      <section id="features" class="section">
        <h2 class="reveal">Everything HomeBank does, in your browser</h2>
        <p class="section-lead reveal">
          Built for feature parity with HomeBank 5.10 — reachable from any device, with the data
          staying on your own server.
        </p>
        <div class="grid">
          {
            features.map((f) => (
              <article class="feature reveal">
                <div class="feature-icon">{f.icon}</div>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </article>
            ))
          }
        </div>
      </section>

      <!-- HomeBank credit -->
      <section id="homebank" class="section split">
        <div class="reveal">
          <h2>Inspired by HomeBank</h2>
          <p>
            CloudBank exists because <a href={HOMEBANK} target="_blank" rel="noopener">HomeBank</a>
            is a wonderful, time-proven desktop app — but it is desktop-only. CloudBank brings the
            same workflow to the web while keeping your data yours.
          </p>
          <p class="muted">
            CloudBank is an <strong>independent, clean-room reimplementation</strong>. It copies no
            HomeBank source code; the original is referenced only for its documented behaviour and
            file formats. CloudBank is released under the AGPL-3.0 (HomeBank is GPL-2+).
          </p>
          <a class="btn" href={HOMEBANK} target="_blank" rel="noopener">Visit HomeBank →</a>
        </div>
        <div class="quote-card reveal">
          <p class="quote">“Native <code>.xhb</code> import &amp; export”</p>
          <p>
            Already using HomeBank? Upload your <code>.xhb</code> file and CloudBank recreates the
            whole wallet — accounts, payees, categories, transactions, transfers, schedules,
            budgets — to the cent. Export back to <code>.xhb</code> any time.
          </p>
        </div>
      </section>

      <!-- The mind behind it -->
      <section id="author" class="section author reveal">
        <h2>The mind behind it</h2>
        <div class="author-card">
          <div class="avatar">CR</div>
          <div>
            <h3>Carlo Ruggiero</h3>
            <p>
              CloudBank is built and maintained by Carlo Ruggiero — a HomeBank user who wanted the
              same trusted workflow on every device, self-hosted and private. It's an open-source
              labour of love; contributions and feedback are welcome.
            </p>
            <div class="author-links">
              <a class="btn small" href={AUTHOR} target="_blank" rel="noopener">GitHub @easly1989</a>
              <a class="btn small donate" href={DONATE} target="_blank" rel="noopener">Buy me a coffee ♥</a>
            </div>
          </div>
        </div>
      </section>

      <!-- Get started -->
      <section id="start" class="section start">
        <h2 class="reveal">Self-host in one command</h2>
        <p class="section-lead reveal">
          You only need Docker with the Compose plugin. Your data lives in the
          <code>cloudbank-data</code> volume — back it up by copying it, or from inside the app.
        </p>
        <pre class="code reveal"><code>{`services:
  cloudbank:
    image: ghcr.io/easly1989/cloudbank:main
    container_name: cloudbank
    restart: unless-stopped
    ports:
      - "8080:8080"
    environment:
      CB_SECURE_COOKIES: "false"   # behind HTTPS? set to "true"
    volumes:
      - cloudbank-data:/data

volumes:
  cloudbank-data:`}</code></pre>
        <p class="run reveal">
          <code>docker compose up -d</code> &nbsp;→&nbsp; open <code>http://localhost:8080</code> and
          complete the first-run admin setup.
        </p>
        <div class="hero-cta reveal">
          <a class="btn primary" href={README} target="_blank" rel="noopener">Full install guide</a>
          <a class="btn" href={REPO} target="_blank" rel="noopener">Star on GitHub ★</a>
          <a class="btn donate" href={DONATE} target="_blank" rel="noopener">Donate</a>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <a class="brand" href="#top">
          <img src={asset("logo.svg")} alt="" width="22" height="22" />
          <span>CloudBank</span>
        </a>
        <nav class="footer-links">
          <a href={REPO} target="_blank" rel="noopener">GitHub</a>
          <a href={`${REPO}/issues`} target="_blank" rel="noopener">Issues</a>
          <a href={HOMEBANK} target="_blank" rel="noopener">HomeBank</a>
          <a href={DONATE} target="_blank" rel="noopener">Donate</a>
        </nav>
        <p class="copy">
          Free &amp; open source under the AGPL-3.0 · A clean-room web port of HomeBank · Not
          affiliated with HomeBank.
        </p>
      </div>
    </footer>

    <script>
      // Reveal-on-scroll: add `.in-view` when an element enters the viewport.
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const els = document.querySelectorAll<HTMLElement>(".reveal");
      if (reduce || !("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("in-view"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("in-view");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>

    <style is:global>
      :root {
        --bg: #0b1120;
        --bg-2: #0f1a30;
        --panel: #131f38;
        --panel-2: #18253f;
        --border: #243352;
        --text: #e8eef7;
        --muted: #9fb0c9;
        --accent: #12b886;
        --accent-2: #15aabf;
        --accent-3: #4dabf7;
        --radius: 16px;
        --maxw: 1080px;
      }
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family:
          system-ui,
          -apple-system,
          "Segoe UI",
          Roboto,
          Helvetica,
          Arial,
          sans-serif;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }
      a {
        color: var(--accent);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      h1,
      h2,
      h3 {
        line-height: 1.15;
        margin: 0 0 0.5em;
      }
      code {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        background: rgba(255, 255, 255, 0.06);
        padding: 0.1em 0.4em;
        border-radius: 6px;
        font-size: 0.92em;
      }

      /* Nav */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.75rem clamp(1rem, 4vw, 2.5rem);
        background: rgba(11, 17, 32, 0.72);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-weight: 800;
        font-size: 1.1rem;
        color: var(--text);
      }
      .brand:hover {
        text-decoration: none;
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: clamp(0.5rem, 2vw, 1.4rem);
      }
      .nav-links a {
        color: var(--muted);
        font-weight: 600;
        font-size: 0.95rem;
      }
      .nav-links a:hover {
        color: var(--text);
        text-decoration: none;
      }
      .nav-links .ghost {
        color: var(--text);
      }
      .nav-links .cta {
        color: #06281f;
        background: var(--accent);
        padding: 0.4rem 0.85rem;
        border-radius: 999px;
      }
      .nav-links .cta:hover {
        filter: brightness(1.08);
      }
      @media (max-width: 620px) {
        .nav-links a:not(.cta):not(.ghost) {
          display: none;
        }
      }

      /* Hero */
      .hero {
        position: relative;
        overflow: hidden;
        text-align: center;
        padding: clamp(3.5rem, 9vw, 7rem) 1.25rem clamp(2.5rem, 6vw, 4.5rem);
      }
      .hero-bg {
        position: absolute;
        inset: -30% -10% auto -10%;
        height: 120%;
        background:
          radial-gradient(40% 50% at 30% 20%, rgba(18, 184, 134, 0.28), transparent 70%),
          radial-gradient(45% 55% at 75% 30%, rgba(77, 171, 247, 0.22), transparent 70%),
          radial-gradient(35% 45% at 55% 80%, rgba(21, 170, 191, 0.18), transparent 70%);
        filter: blur(8px);
        animation: drift 18s ease-in-out infinite alternate;
      }
      @keyframes drift {
        from {
          transform: translate3d(-2%, -1%, 0) scale(1);
        }
        to {
          transform: translate3d(3%, 2%, 0) scale(1.08);
        }
      }
      .hero-inner {
        position: relative;
        max-width: 820px;
        margin: 0 auto;
      }
      .hero-logo {
        filter: drop-shadow(0 10px 30px rgba(18, 184, 134, 0.45));
      }
      .float {
        animation: float 6s ease-in-out infinite;
      }
      @keyframes float {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-10px);
        }
      }
      .hero h1 {
        font-size: clamp(2.4rem, 7vw, 4rem);
        margin-top: 1rem;
        letter-spacing: -0.02em;
      }
      .grad {
        background: linear-gradient(100deg, var(--accent), var(--accent-2) 50%, var(--accent-3));
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .lead {
        font-size: clamp(1.05rem, 2.4vw, 1.3rem);
        color: var(--muted);
        max-width: 640px;
        margin: 0 auto 1.6rem;
      }
      .hero-cta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
      }
      .badges {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: center;
        margin-top: 1.8rem;
      }
      .badges span {
        font-size: 0.8rem;
        color: var(--muted);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.25rem 0.7rem;
      }

      /* Buttons */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.7rem 1.25rem;
        border-radius: 999px;
        font-weight: 700;
        font-size: 0.98rem;
        color: var(--text);
        background: var(--panel-2);
        border: 1px solid var(--border);
        transition:
          transform 0.15s ease,
          filter 0.15s ease,
          background 0.15s ease;
      }
      .btn:hover {
        text-decoration: none;
        transform: translateY(-2px);
        filter: brightness(1.1);
      }
      .btn.primary {
        background: linear-gradient(100deg, var(--accent), var(--accent-2));
        color: #04241b;
        border-color: transparent;
      }
      .btn.donate {
        background: transparent;
        border-color: var(--accent);
        color: var(--accent);
      }
      .btn.small {
        padding: 0.5rem 0.95rem;
        font-size: 0.9rem;
      }

      /* Preview window */
      .preview {
        max-width: var(--maxw);
        margin: -1rem auto 0;
        padding: 0 1.25rem;
      }
      .window {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--panel);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
        overflow: hidden;
      }
      .window-bar {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.6rem 0.9rem;
        background: var(--panel-2);
        border-bottom: 1px solid var(--border);
      }
      .dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        display: inline-block;
      }
      .dot.r {
        background: #ff5f57;
      }
      .dot.y {
        background: #febc2e;
      }
      .dot.g {
        background: #28c840;
      }
      .url {
        margin-left: 0.6rem;
        font-size: 0.8rem;
        color: var(--muted);
      }
      .window-body {
        display: grid;
        grid-template-columns: 76px 1fr;
        gap: 0;
        min-height: 320px;
      }
      .mock-nav {
        background: var(--bg-2);
        border-right: 1px solid var(--border);
        padding: 0.9rem 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.7rem;
      }
      .mock-logo {
        width: 26px;
        height: 26px;
        border-radius: 8px;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        margin-bottom: 0.6rem;
      }
      .mock-nav i {
        width: 40px;
        height: 9px;
        border-radius: 5px;
        background: var(--border);
      }
      .mock-nav i.active {
        background: var(--accent);
      }
      .mock-main {
        padding: 1.1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }
      .mock-row {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(3, 1fr);
      }
      .mock-row:nth-child(2) {
        grid-template-columns: 2fr 1fr;
      }
      .mock-card {
        background: var(--panel-2);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.9rem;
      }
      .mock-card.kpi b {
        font-size: 1.25rem;
        display: block;
        color: var(--text);
      }
      .mock-card.kpi small {
        color: var(--muted);
      }
      .mock-card.chart {
        min-height: 130px;
        display: flex;
        align-items: flex-end;
      }
      .bars {
        display: flex;
        align-items: flex-end;
        gap: 8px;
        width: 100%;
        height: 100px;
      }
      .bars i {
        flex: 1;
        background: linear-gradient(180deg, var(--accent), var(--accent-2));
        border-radius: 4px 4px 0 0;
        animation: grow 1.4s ease both;
        transform-origin: bottom;
      }
      .bars i:nth-child(1) {
        height: 40%;
      }
      .bars i:nth-child(2) {
        height: 70%;
      }
      .bars i:nth-child(3) {
        height: 55%;
      }
      .bars i:nth-child(4) {
        height: 85%;
      }
      .bars i:nth-child(5) {
        height: 60%;
      }
      .bars i:nth-child(6) {
        height: 95%;
      }
      .bars i:nth-child(7) {
        height: 50%;
      }
      .bars i:nth-child(8) {
        height: 75%;
      }
      @keyframes grow {
        from {
          transform: scaleY(0);
        }
      }
      .mock-card.donut {
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .ring {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        background: conic-gradient(
          var(--accent) 0 38%,
          var(--accent-2) 38% 62%,
          var(--accent-3) 62% 82%,
          var(--border) 82% 100%
        );
        -webkit-mask: radial-gradient(circle 30px at center, transparent 98%, #000 100%);
        mask: radial-gradient(circle 30px at center, transparent 98%, #000 100%);
      }

      /* Sections */
      .section {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: clamp(3.5rem, 8vw, 6rem) 1.25rem;
      }
      .section h2 {
        font-size: clamp(1.7rem, 4vw, 2.4rem);
        text-align: center;
        letter-spacing: -0.01em;
      }
      .section-lead {
        text-align: center;
        color: var(--muted);
        max-width: 640px;
        margin: 0 auto 2.5rem;
      }
      .grid {
        display: grid;
        gap: 1.1rem;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      }
      .feature {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.4rem;
        transition:
          transform 0.2s ease,
          border-color 0.2s ease;
      }
      .feature:hover {
        transform: translateY(-4px);
        border-color: var(--accent);
      }
      .feature-icon {
        font-size: 1.7rem;
        margin-bottom: 0.4rem;
      }
      .feature h3 {
        font-size: 1.1rem;
      }
      .feature p {
        color: var(--muted);
        margin: 0;
        font-size: 0.96rem;
      }

      .split {
        display: grid;
        gap: 2rem;
        grid-template-columns: 1.1fr 0.9fr;
        align-items: center;
      }
      .split h2 {
        text-align: left;
      }
      .split p {
        color: var(--text);
      }
      .split .muted {
        color: var(--muted);
        font-size: 0.95rem;
      }
      .quote-card {
        background: linear-gradient(160deg, var(--panel), var(--panel-2));
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.6rem;
      }
      .quote {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--accent);
        margin-top: 0;
      }
      @media (max-width: 760px) {
        .split {
          grid-template-columns: 1fr;
        }
      }

      /* Author */
      .author h2 {
        margin-bottom: 1.5rem;
      }
      .author-card {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 1.4rem;
        align-items: center;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.6rem;
      }
      .avatar {
        width: 84px;
        height: 84px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-weight: 800;
        font-size: 1.6rem;
        color: #04241b;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
      }
      .author-card h3 {
        margin-bottom: 0.3rem;
      }
      .author-card p {
        color: var(--muted);
        margin-top: 0;
      }
      .author-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin-top: 0.4rem;
      }
      @media (max-width: 560px) {
        .author-card {
          grid-template-columns: 1fr;
          text-align: center;
          justify-items: center;
        }
      }

      /* Start */
      .start {
        text-align: center;
      }
      .code {
        text-align: left;
        max-width: 640px;
        margin: 0 auto 1.2rem;
        background: #07101f;
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.1rem 1.3rem;
        overflow-x: auto;
        font-size: 0.88rem;
        line-height: 1.5;
      }
      .code code {
        background: none;
        padding: 0;
        color: #cfe6dd;
      }
      .run {
        color: var(--muted);
      }

      /* Footer */
      .footer {
        border-top: 1px solid var(--border);
        background: var(--bg-2);
      }
      .footer-inner {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 2rem 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.8rem;
        text-align: center;
      }
      .footer-links {
        display: flex;
        gap: 1.2rem;
        flex-wrap: wrap;
        justify-content: center;
      }
      .footer-links a {
        color: var(--muted);
        font-weight: 600;
      }
      .copy {
        color: var(--muted);
        font-size: 0.85rem;
        margin: 0;
      }

      /* Reveal animation — only hide when JS is present to reveal it again. */
      .js .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition:
          opacity 0.7s ease,
          transform 0.7s ease;
      }
      .js .reveal.in-view {
        opacity: 1;
        transform: none;
      }
      @media (prefers-reduced-motion: reduce) {
        .js .reveal {
          opacity: 1;
          transform: none;
          transition: none;
        }
        .float,
        .hero-bg,
        .bars i {
          animation: none;
        }
      }
    </style>
  </body>
</html>
